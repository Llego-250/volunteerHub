title Application State Management

object AppState {
  currentUser: Object
  events: Array
  organizerEvents: Array
  categories: Array
}

object currentUser {
  id: Integer
  name: String
  email: String
  role: String
  phone: String
  location: String
  registeredEvents: Array
}

object localStorage {
  volunteerHubUser
  volunteerHubEvents
  volunteerHubUsers
}

object sessionStorage {
  showProfile: Boolean
  showSettings: Boolean
}

AppState *-- currentUser
AppState --> localStorage : save/load
AppState --> sessionStorage : flags

note right of AppState
  Global application state
  Initialized on page load
  Updated on user actions
end note

note right of localStorage
  Persistent storage
  Survives page refresh
  Used for auto-login
end note

note right of sessionStorage
  Temporary storage
  Cleared on tab close
  Used for UI flags
end note

