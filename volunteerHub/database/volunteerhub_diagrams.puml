@startuml VolunteerHub_Sequence_Diagram_User_Registration
title Sequence Diagram: User Registration and Event Sign-up

actor Volunteer
participant "Web Browser" as Browser
participant "auth.js" as AuthJS
participant "users.php API" as UserAPI
participant "Database" as DB

Volunteer -> Browser: Navigate to platform
Browser -> Browser: Display registration modal
Volunteer -> Browser: Fill registration form\n(name, email, password, role)
Browser -> AuthJS: Submit registration
AuthJS -> AuthJS: Validate form data
AuthJS -> UserAPI: POST /api/users.php\n{name, email, password, role}
UserAPI -> UserAPI: Hash password (bcrypt)
UserAPI -> DB: INSERT INTO users
DB --> UserAPI: User created (user_id)
UserAPI --> AuthJS: {success: true, user: {...}}
AuthJS -> AuthJS: Store user session
AuthJS --> Browser: Redirect to dashboard
Browser --> Volunteer: Display volunteer dashboard

@enduml

@startuml VolunteerHub_Sequence_Diagram_Event_Registration
title Sequence Diagram: Volunteer Event Registration

actor Volunteer
participant "Browser" as Browser
participant "events-page.js" as EventJS
participant "events.php API" as EventAPI
participant "registrations.php API" as RegAPI
participant "Database" as DB

Volunteer -> Browser: Browse events page
Browser -> EventJS: Load events
EventJS -> EventAPI: GET /api/events.php
EventAPI -> DB: SELECT * FROM events
DB --> EventAPI: Event list
EventAPI --> EventJS: JSON events data
EventJS --> Browser: Display event cards

Volunteer -> Browser: Click "Register" button
Browser -> EventJS: Trigger registration
EventJS -> RegAPI: POST /api/registrations.php\n{event_id, user_id}
RegAPI -> DB: Check capacity & existing registration
DB --> RegAPI: Validation result
RegAPI -> DB: INSERT INTO event_registrations
DB --> RegAPI: Registration created
RegAPI -> DB: UPDATE events SET current_participants
DB --> RegAPI: Updated
RegAPI --> EventJS: {success: true, message}
EventJS --> Browser: Show success notification
Browser --> Volunteer: Display updated UI

@enduml

@startuml VolunteerHub_Sequence_Diagram_Messaging
title Sequence Diagram: User Messaging System

actor User1 as "User (Sender)"
participant "Browser" as Browser
participant "volunteer-dashboard.js" as DashJS
participant "messages.php API" as MsgAPI
participant "Database" as DB
actor User2 as "User (Receiver)"

User1 -> Browser: Open messages section
Browser -> DashJS: Load conversations
DashJS -> MsgAPI: GET /api/messages.php?user_id=X
MsgAPI -> DB: SELECT messages WHERE\nsender_id=X OR receiver_id=X
DB --> MsgAPI: Message list
MsgAPI --> DashJS: JSON messages
DashJS --> Browser: Display conversation list

User1 -> Browser: Select conversation/compose new
User1 -> Browser: Type message content
Browser -> DashJS: Submit message
DashJS -> MsgAPI: POST /api/messages.php\n{sender_id, receiver_id, content}
MsgAPI -> DB: INSERT INTO messages
DB --> MsgAPI: Message created
MsgAPI --> DashJS: {success: true}
DashJS --> Browser: Update conversation view
Browser --> User1: Display sent message

note right of User2
  User2 will see new message
  when they refresh or
  load messages
end note

@enduml

@startuml VolunteerHub_Sequence_Diagram_Hour_Logging
title Sequence Diagram: Volunteer Hour Logging and Approval

actor Volunteer
participant "Browser" as Browser
participant "volunteer-dashboard.js" as VolDash
participant "hours.php API" as HourAPI
participant "Database" as DB
actor Organizer
participant "organizer-dashboard.js" as OrgDash

Volunteer -> Browser: Navigate to "Log Hours"
Browser -> VolDash: Display hour logging form
Volunteer -> Browser: Enter hours details\n(event_id, hours, description)
Browser -> VolDash: Submit hours
VolDash -> HourAPI: POST /api/hours.php\n{user_id, event_id, hours, description}
HourAPI -> DB: INSERT INTO volunteer_hours\n(status='pending')
DB --> HourAPI: Hours logged
HourAPI --> VolDash: {success: true}
VolDash --> Browser: Show success message
Browser --> Volunteer: Display pending hours

... Hours await approval ...

Organizer -> Browser: Open organizer dashboard
Browser -> OrgDash: Load pending hours
OrgDash -> HourAPI: GET /api/hours.php?status=pending
HourAPI -> DB: SELECT * FROM volunteer_hours\nWHERE status='pending'
DB --> HourAPI: Pending hours list
HourAPI --> OrgDash: JSON data
OrgDash --> Browser: Display approval table

Organizer -> Browser: Review and approve hours
Browser -> OrgDash: Approve hours
OrgDash -> HourAPI: PUT /api/hours.php\n{hour_id, status='approved'}
HourAPI -> DB: UPDATE volunteer_hours\nSET status='approved'
DB --> HourAPI: Updated
HourAPI -> HourAPI: Check badge eligibility
HourAPI -> DB: Award badges if threshold met
DB --> HourAPI: Badge awarded
HourAPI --> OrgDash: {success: true}
OrgDash --> Browser: Update UI
Browser --> Organizer: Show approved status

@enduml

