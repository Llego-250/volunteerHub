@startuml
title VolunteerHub - Complete User Flow

actor User
participant "Landing Page" as LP
participant "Auth System" as Auth
participant "API" as API
database "Database" as DB
participant "Volunteer Dashboard" as VD
participant "Organizer Dashboard" as OD

User -> LP: Visit Website
LP -> User: Show Featured Events

alt Login
    User -> Auth: Click Login
    User -> Auth: Enter Email, Password, Role
    Auth -> API: POST /api/users.php?action=login
    API -> DB: Validate Credentials
    DB -> API: User Data
    
    alt Role = Volunteer
        API -> VD: Redirect
        VD -> User: Show Volunteer Dashboard
    else Role = Organizer
        API -> OD: Redirect
        OD -> User: Show Organizer Dashboard
    end
    
else Signup
    User -> Auth: Click Signup
    User -> Auth: Enter Details
    Auth -> API: POST /api/users.php?action=register
    API -> DB: Create Account
    DB -> API: Success
    
    alt Role = Volunteer
        API -> VD: Redirect
        VD -> User: Show Volunteer Dashboard
    else Role = Organizer
        API -> OD: Redirect
        OD -> User: Show Organizer Dashboard
    end
end

@enduml

@startuml
title Volunteer - Event Registration Flow

actor Volunteer
participant "Dashboard" as VD
participant "Events API" as API
database "Database" as DB

Volunteer -> VD: Browse Events
VD -> API: GET /api/events.php
API -> DB: Fetch Events
DB -> API: Events List
API -> VD: Display Events
VD -> Volunteer: Show Available Events

Volunteer -> VD: Search/Filter Events
Volunteer -> VD: Click Event Card
VD -> Volunteer: Show Event Details Modal

Volunteer -> VD: Click Register
VD -> API: POST /api/events.php?action=register
API -> DB: Check Availability
alt Event Available
    DB -> API: Success
    API -> DB: Add Registration
    API -> DB: Increment Volunteer Count
    DB -> API: Updated
    API -> VD: Registration Success
    VD -> Volunteer: Show Success Message
    VD -> Volunteer: Update My Events
else Event Full
    DB -> API: Full
    API -> VD: Event Full
    VD -> Volunteer: Show Full Message
end

@enduml

@startuml
title Organizer - Event Creation Flow

actor Organizer
participant "Dashboard" as OD
participant "Events API" as API
database "Database" as DB

Organizer -> OD: Click Create Event
OD -> Organizer: Show Event Form

Organizer -> OD: Enter Title
Organizer -> OD: Select Category
Organizer -> OD: Set Date & Time
Organizer -> OD: Enter Location
Organizer -> OD: Set Max Volunteers
Organizer -> OD: Enter Description
Organizer -> OD: Click Submit

OD -> API: POST /api/events.php
API -> API: Validate Date (Future)

alt Valid Date
    API -> DB: INSERT Event
    DB -> API: Event ID
    API -> OD: Success
    OD -> Organizer: Show Success Message
    OD -> Organizer: Display in My Events
else Invalid Date
    API -> OD: Date Error
    OD -> Organizer: Show Error Message
end

@enduml

@startuml
title Organizer - Volunteer Management Flow

actor Organizer
participant "Dashboard" as OD
participant "Events API" as API
database "Database" as DB

Organizer -> OD: View Event
Organizer -> OD: Click View Volunteers
OD -> API: GET /api/events.php?event_id={id}&action=volunteers
API -> DB: Fetch Volunteers
DB -> API: Volunteer List
API -> OD: Display List

alt Has Volunteers
    OD -> Organizer: Show Volunteer Cards
    
    alt Action: Call
        Organizer -> OD: Click Call
        OD -> Organizer: Open Phone Dialer
    else Action: Email
        Organizer -> OD: Click Email
        OD -> Organizer: Open Email Client
    else Action: Message
        Organizer -> OD: Click Message
        OD -> Organizer: Show Message Form
        Organizer -> OD: Enter Message
        OD -> API: POST /api/messages.php
        API -> DB: Save Message
        DB -> API: Success
        API -> OD: Message Sent
        OD -> Organizer: Show Success
    else Action: Remove
        Organizer -> OD: Click Remove
        OD -> Organizer: Confirm Removal
        Organizer -> OD: Confirm
        OD -> API: DELETE /api/events.php?action=unregister
        API -> DB: Remove Registration
        API -> DB: Decrement Count
        DB -> API: Success
        API -> OD: Updated
        OD -> Organizer: Show Removed Message
    end
else No Volunteers
    OD -> Organizer: Show Empty State
end

@enduml

@startuml
title Messaging System Flow

actor Organizer
participant "Organizer Dashboard" as OD
participant "Messages API" as MAPI
database "Database" as DB
participant "Volunteer Dashboard" as VD
actor Volunteer

== Organizer Sends Message ==
Organizer -> OD: Click Message Volunteers
OD -> MAPI: GET /api/registrations.php?organizer_id={id}
MAPI -> DB: Fetch Volunteers
DB -> MAPI: Volunteer List
MAPI -> OD: Display List
OD -> Organizer: Show Volunteers

Organizer -> OD: Select Volunteer
Organizer -> OD: Enter Message
Organizer -> OD: Click Send
OD -> MAPI: POST /api/messages.php
MAPI -> DB: INSERT Message (is_read=false)
DB -> MAPI: Success
MAPI -> OD: Message Sent
OD -> Organizer: Show Success

== Volunteer Receives Message ==
Volunteer -> VD: Login to Dashboard
VD -> MAPI: GET /api/messages.php?user_id={id}
MAPI -> DB: Fetch Messages
DB -> MAPI: Messages List
MAPI -> VD: Count Unread
VD -> Volunteer: Update Badge (Unread Count)

Volunteer -> VD: Click Notification Bell
VD -> Volunteer: Show Messages Modal

Volunteer -> VD: Click Message
VD -> MAPI: PUT /api/messages.php (Mark Read)
MAPI -> DB: UPDATE is_read=true
DB -> MAPI: Success
MAPI -> VD: Updated
VD -> Volunteer: Update Badge Count

@enduml

@startuml
title System Architecture

package "Frontend" {
    component [Landing Page] as LP
    component [Volunteer Dashboard] as VD
    component [Organizer Dashboard] as OD
    component [Auth Components] as Auth
}

package "Backend API" {
    component [users.php] as UP
    component [events.php] as EP
    component [messages.php] as MP
    component [registrations.php] as RP
    component [hours.php] as HP
    component [badges.php] as BP
}

database "MySQL Database" {
    storage [users]
    storage [events]
    storage [event_registrations]
    storage [messages]
    storage [volunteer_hours]
    storage [badges]
    storage [user_badges]
}

LP --> Auth
Auth --> UP
VD --> EP
VD --> MP
VD --> HP
VD --> BP
OD --> EP
OD --> MP
OD --> RP

UP --> [users]
EP --> [events]
EP --> [event_registrations]
MP --> [messages]
RP --> [event_registrations]
HP --> [volunteer_hours]
BP --> [badges]
BP --> [user_badges]

@enduml

@startuml
title Volunteer Dashboard Flow

start
:Login as Volunteer;
:Load Dashboard;

partition "Dashboard Sections" {
    :Display Stats;
    note right
        - Total Registered Events
        - Upcoming Events
        - Completed Events
    end note
    
    fork
        :My Events;
        :View Registered Events;
        :Filter Events;
        :Unregister Option;
    fork again
        :Browse Events;
        :Search Events;
        :Filter by Category;
        :Register for Events;
    fork again
        :Notifications;
        :View Messages;
        :Mark as Read;
    fork again
        :Hours & Badges;
        :View Volunteer Hours;
        :View Achievements;
    end fork
}

stop
@enduml

@startuml
title Organizer Dashboard Flow

start
:Login as Organizer;
:Load Dashboard;

partition "Dashboard Sections" {
    :Display Stats;
    note right
        - Total Events Created
        - Total Volunteers
        - Active Events
    end note
    
    fork
        :My Events;
        :View Created Events;
        :Filter Events;
        :Manage Events;
    fork again
        :Create Event;
        :Fill Event Form;
        :Submit Event;
    fork again
        :Volunteer Management;
        :View Volunteers;
        :Contact Volunteers;
        :Remove Volunteers;
    fork again
        :Messaging;
        :Select Volunteer;
        :Send Message;
    end fork
}

stop
@enduml
